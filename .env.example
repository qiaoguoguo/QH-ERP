# 本文件只用于本地开发 compose.yaml，不得作为 production profile 或 compose.production.yaml 的密钥来源。
QHERP_POSTGRES_DB=qherp
QHERP_POSTGRES_USER=qherp
QHERP_POSTGRES_PASSWORD=qherp_dev_password
QHERP_POSTGRES_PORT=15432
QHERP_DATASOURCE_URL=jdbc:postgresql://localhost:15432/qherp
QHERP_DATASOURCE_USERNAME=qherp
QHERP_DATASOURCE_PASSWORD=qherp_dev_password
QHERP_MINIO_ROOT_USER=qherpminio
QHERP_MINIO_ROOT_PASSWORD=qherpminio123
QHERP_MINIO_API_PORT=19000
QHERP_MINIO_CONSOLE_PORT=19001
QHERP_S3_ENDPOINT=http://localhost:19000
QHERP_S3_REGION=us-east-1
QHERP_S3_BUCKET=qherp-private
QHERP_S3_ACCESS_KEY=qherpminio
QHERP_S3_SECRET_KEY=qherpminio123
QHERP_S3_PATH_STYLE=true

# 生产环境使用 tools/production/initialize-secrets.ps1 创建当前 Windows 用户 DPAPI 加密载体，
# 再通过 tools/production/invoke-production.ps1 受控注入；仓库不提供任何生产密码默认值。
